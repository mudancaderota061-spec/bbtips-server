{
  "manifest_version": 3,
  "name": "BBTips Robô",
  "version": "1.0.83",
  "description": "Injeta o robô BBTips somente após ativação da licença.",
  "permissions": ["storage", "activeTab", "scripting"],
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'; connect-src 'self' https://* http://*"
  },
  "background": {
    "service_worker": "background.js"
  },
  "host_permissions": [
    "*://*.bbtips.com.br/*",
    "*://bbtips.com.br/*",
    "*://*.bbtips.com/*",
    "*://bbtips.com/*",
    "*://*.thtips.com.br/*",
    "*://thtips.com.br/*",
    "*://*.caramelotips.com.br/*",
    "*://caramelotips.com.br/*",
    "https://bbtips-server-production.up.railway.app/*",
    "https://bbtips-server.onrender.com/*",
    "https://*.up.railway.app/*",
    "https://*.railway.app/*",
    "https://*/*",
    "http://*/*"
  ],
  "action": {
    "default_title": "BBTips Robô",
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": [
        "*://*.bbtips.com.br/*",
        "*://bbtips.com.br/*",
        "*://*.bbtips.com/*",
        "*://bbtips.com/*",
        "*://*.thtips.com.br/*",
        "*://thtips.com.br/*",
        "*://*.caramelotips.com.br/*",
        "*://caramelotips.com.br/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["robot.js"],
      "matches": [
        "*://*.bbtips.com.br/*",
        "*://bbtips.com.br/*",
        "*://*.bbtips.com/*",
        "*://bbtips.com/*",
        "*://*.thtips.com.br/*",
        "*://thtips.com.br/*",
        "*://*.caramelotips.com.br/*",
        "*://caramelotips.com.br/*"
      ]
    }
  ]
}
